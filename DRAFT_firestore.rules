rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock', 'category']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerId', 'items', 'status', 'deliveryDate', 'total']) &&
             data.customerId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.status in ['pending', 'confirmed', 'out_for_delivery', 'delivered', 'cancelled'] &&
             data.deliveryDate is string &&
             data.total is number && data.total >= 0;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manual setup or cloud function
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'companyName', 'pib', 'address', 'phone']);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if (isAdmin() || (isOwner(existing().customerId) && incoming().status == 'cancelled' && existing().status == 'pending')) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['status', 'isPaid', 'trackingUrl']);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
