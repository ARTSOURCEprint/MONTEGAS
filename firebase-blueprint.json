{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "companyName": { "type": "string" },
        "pib": { "type": "string", "description": "Tax ID for legal entities" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Gas product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "unit": { "type": "string", "enum": ["kg", "l", "pcs"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Gas delivery order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "out_for_delivery", "delivered", "cancelled"] },
        "deliveryDate": { "type": "string", "format": "date" },
        "deliveryTime": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["invoice", "card", "cash"] },
        "total": { "type": "number" },
        "isPaid": { "type": "boolean" },
        "trackingUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "items", "status", "deliveryDate", "total"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User favorites.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array" }
      },
      "required": ["userId", "productIds"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Delivery orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/wishlists/{userId}": {
      "schema": "Wishlist",
      "description": "User wishlists"
    },
    "/admins/{userId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Admin list for role verification"
    }
  }
}
